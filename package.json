{
  "name": "obsidian-dnd-vtt",
  "version": "0.0.1",
  "description": "A virtual tabletop for D&D 5e, built as an Obsidian plugin.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run"
  },
  "keywords": [
    "obsidian",
    "dnd",
    "vtt",
    "ttrpg"
  ],
  "author": "Mehras Meydani",
  "license": "MIT",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.23.0",
    "jsdom": "^25.0.0",
    "obsidian": "^1.5.7",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
